---
import "../global.css";
import CardContent from "./CardContent.astro";
import CopperPad from "../images/SVGs/copper_pad.svg";

const {
  slug,
  title,
  tags,
  img_src,
  alt_text,
  date,
  read_time,
  paragrafo,
  draft,
} = Astro.props;
const formattedDate = date.toLocaleDateString("pt-BR");
---

<div
  class:list={[
    "relative w-full max-w-4xl min-h-64 rounded-md shadow-md shadow-black/25 ring-2 ring-inset ring-pcb-ring bg-pcb-green hover:bg-pcb-green-hover flex justify-center group",
    draft ? "draft hidden" : "",
  ]}
>
  <!-- Make it clickable (i hate this solution and acessibility must be shit, besides reading the title twice) -->
  <a href={`/blog/${slug}`} class="absolute inset-0 z-10" aria-label={title}
  ></a>

  <!-- absolute firulas douradas -->

  <!-- <div
    class="absolute top-2 left-2 size-[14px] border-[3.5px] rounded-full
      bg-dark-grey border-copper"
  >
  </div>
  <div
    class="absolute top-2 right-2 md:top-auto md:right-auto md:bottom-2 md:left-2
    size-[14px] border-[3.5px] rounded-full
      bg-dark-grey border-copper"
  >
  </div> -->

  <CopperPad class="absolute left-2 top-2 fill-dark-grey text-copper" />
  <CopperPad
    class="absolute right-2 top-2 md:top-auto md:right-auto md:bottom-2 md:left-2 fill-dark-grey text-copper"
  />

  <CardContent
    title={title}
    tags={tags}
    img_src={img_src}
    alt_text={alt_text}
    date={date}
    read_time={read_time}
    paragrafo={paragrafo}
  />
</div>
