---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "./Navbar.astro";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  loadKatex?: boolean;
}

const { title, description, bodyClass, loadKatex = false } = Astro.props;
---

<BaseLayout title={title} description={description} bodyClass={bodyClass} activeFonts={["montserrat", "jetbrains-mono"]} loadKatex={loadKatex}>
  <Navbar />
  <main>
    <slot />
  </main>
</BaseLayout>
